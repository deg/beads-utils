#!/usr/bin/env python3
"""Export a beads project to a CSV suitable for project review."""
from __future__ import annotations

import argparse
import csv
import json
import subprocess
import sys
from datetime import date
from pathlib import Path

COLUMNS = [
    "id", "title", "type", "status", "priority",
    "assignee", "owner",
    "created_at", "updated_at", "closed_at", "close_reason",
    "labels", "dependencies",
    "spec_id", "defer_until", "external_ref",
    "description", "notes", "design", "acceptance_criteria",
    "dependency_count", "dependent_count", "comment_count",
]

SORT_KEYS = {
    "id", "title", "type", "status", "priority",
    "assignee", "owner",
    "created_at", "updated_at", "closed_at",
}


def run_bd_export(project_path: Path) -> str:
    try:
        result = subprocess.run(
            ["bd", "export", "--all", "--no-memories"],
            cwd=project_path,
            capture_output=True,
            text=True,
            check=True,
        )
    except FileNotFoundError:
        sys.exit("error: 'bd' not found on PATH")
    except subprocess.CalledProcessError as exc:
        if exc.stderr:
            sys.stderr.write(exc.stderr)
        sys.exit(f"error: bd export failed (exit {exc.returncode})")
    return result.stdout


def format_labels(labels) -> str:
    if not labels:
        return ""
    return "|".join(sorted(labels))


def format_dependencies(deps) -> str:
    if not deps:
        return ""
    return "|".join(
        f"{d.get('type', '?')}:{d.get('depends_on_id', '?')}" for d in deps
    )


def issue_to_row(issue: dict) -> dict:
    return {
        "id": issue.get("id", ""),
        "title": issue.get("title", ""),
        "type": issue.get("issue_type", ""),
        "status": issue.get("status", ""),
        "priority": issue.get("priority", ""),
        "assignee": issue.get("assignee", ""),
        "owner": issue.get("owner", ""),
        "created_at": issue.get("created_at", ""),
        "updated_at": issue.get("updated_at", ""),
        "closed_at": issue.get("closed_at", ""),
        "close_reason": issue.get("close_reason", ""),
        "labels": format_labels(issue.get("labels")),
        "dependencies": format_dependencies(issue.get("dependencies")),
        "spec_id": issue.get("spec_id", ""),
        "defer_until": issue.get("defer_until", ""),
        "external_ref": issue.get("external_ref", ""),
        "description": issue.get("description", ""),
        "notes": issue.get("notes", ""),
        "design": issue.get("design", ""),
        "acceptance_criteria": issue.get("acceptance_criteria", ""),
        "dependency_count": issue.get("dependency_count", ""),
        "dependent_count": issue.get("dependent_count", ""),
        "comment_count": issue.get("comment_count", ""),
    }


def derive_prefix(issues: list[dict], fallback: str) -> str:
    for issue in issues:
        iid = issue.get("id", "")
        if "-" in iid:
            return iid.split("-", 1)[0]
    return fallback


def parse_sortby(spec: str) -> list[tuple[str, bool]]:
    keys: list[tuple[str, bool]] = []
    for token in spec.split(","):
        token = token.strip()
        if not token:
            continue
        desc = token.startswith("-")
        key = token.lstrip("-+")
        if key not in SORT_KEYS:
            sys.exit(
                f"error: --sortby: unknown key {key!r} "
                f"(valid: {', '.join(sorted(SORT_KEYS))})"
            )
        keys.append((key, desc))
    return keys


def apply_sort(rows: list[dict], keys: list[tuple[str, bool]]) -> None:
    for key, desc in reversed(keys):
        rows.sort(key=lambda r, k=key: str(r[k]), reverse=desc)


def main() -> int:
    parser = argparse.ArgumentParser(
        description="Export a beads project to CSV for project review."
    )
    parser.add_argument(
        "project_path", nargs="?", default=".",
        help="Path to the beads project (default: current directory)",
    )
    parser.add_argument(
        "-o", "--output", default=None,
        help="Output CSV path (default: <prefix>-issues-<YYYY-MM-DD>.csv in cwd)",
    )
    parser.add_argument(
        "--sortby", default=None, metavar="KEYS",
        help=(
            "Comma-separated sort keys; prefix with '-' for descending "
            "(e.g., 'priority,-created_at'). "
            "Use '--sortby=-key,...' (with '=') when the first key is "
            "descending, so argparse doesn't treat it as a flag. "
            "Keys: " + ", ".join(sorted(SORT_KEYS))
        ),
    )
    args = parser.parse_args()

    sort_keys = parse_sortby(args.sortby) if args.sortby else []

    project_path = Path(args.project_path).expanduser().resolve()
    if not (project_path / ".beads").is_dir():
        sys.exit(f"error: no .beads/ directory at {project_path}")

    jsonl = run_bd_export(project_path)
    issues = [json.loads(line) for line in jsonl.splitlines() if line.strip()]

    if not issues:
        sys.stderr.write("warning: no issues in project; writing header-only CSV\n")

    prefix = derive_prefix(issues, fallback=project_path.name)
    today = date.today().isoformat()
    if args.output:
        output = Path(args.output).expanduser()
    else:
        output = Path.cwd() / f"{prefix}-issues-{today}.csv"

    rows = [issue_to_row(issue) for issue in issues]
    if sort_keys:
        apply_sort(rows, sort_keys)

    with output.open("w", newline="", encoding="utf-8") as f:
        writer = csv.DictWriter(f, fieldnames=COLUMNS, quoting=csv.QUOTE_MINIMAL)
        writer.writeheader()
        writer.writerows(rows)

    print(output.resolve())
    return 0


if __name__ == "__main__":
    sys.exit(main())
