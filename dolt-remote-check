#!/usr/bin/env python3
"""Verify that a beads project's Dolt data has been pushed to the remote.

Dolt stores its data under refs/dolt/data in the Git remote — invisible in
GitHub's web UI but durable alongside your normal branches. This script
compares local Dolt state (embedded or server mode) against what's on the
remote and reports whether they're in sync.
"""
from __future__ import annotations

import argparse
import functools
import json
import re
import shutil
import subprocess
import sys
from pathlib import Path

from bdutils import error, resolve_project_path

ANSI_RE = re.compile(r"\x1b\[[0-9;]*m")


def strip_ansi(s: str) -> str:
    return ANSI_RE.sub("", s)


def run(cmd: list[str], cwd: Path, check: bool = False) -> subprocess.CompletedProcess[str]:
    return subprocess.run(cmd, cwd=cwd, capture_output=True, text=True, check=check)


def read_metadata(beads_dir: Path) -> tuple[str, str]:
    path = beads_dir / "metadata.json"
    if not path.is_file():
        error(f"no metadata.json in {beads_dir}")
    try:
        data = json.loads(path.read_text())
    except (OSError, json.JSONDecodeError) as exc:
        error(f"could not read {path}: {exc}")
    db_name = data.get("dolt_database", "unknown")
    dolt_mode = data.get("dolt_mode", "unknown")
    return db_name, dolt_mode


def get_remote_url(project_path: Path) -> str:
    result = run(["git", "remote", "get-url", "origin"], cwd=project_path)
    url = result.stdout.strip()
    return url if url else "(no remote)"


def get_remote_dolt_ref(project_path: Path) -> str | None:
    result = run(["git", "ls-remote", "origin", "refs/dolt/data"], cwd=project_path)
    line = result.stdout.strip()
    if not line:
        return None
    return line.split()[0]


def read_push_state(beads_dir: Path) -> tuple[str | None, str | None]:
    path = beads_dir / "push-state.json"
    if not path.is_file():
        return None, None
    try:
        data = json.loads(path.read_text())
    except (OSError, json.JSONDecodeError):
        return None, None
    return data.get("last_push"), data.get("last_commit")


def locate_dolt_db(beads_dir: Path, db_name: str) -> Path | None:
    for candidate in (beads_dir / "embeddeddolt" / db_name, beads_dir / "dolt" / db_name):
        if (candidate / ".dolt").is_dir():
            return candidate
    return None


def read_dolt_remotes(dolt_db_dir: Path) -> dict[str, str]:
    repo_state = dolt_db_dir / ".dolt" / "repo_state.json"
    if not repo_state.is_file():
        return {}
    try:
        data = json.loads(repo_state.read_text())
    except (OSError, json.JSONDecodeError):
        return {}
    remotes = data.get("remotes", {}) or {}
    return {name: r.get("url", "?") for name, r in remotes.items()}


def get_local_dolt_head(dolt_db_dir: Path) -> str | None:
    if not _have_dolt():
        return None
    result = run(["dolt", "log", "--oneline", "-n", "1"], cwd=dolt_db_dir)
    if result.returncode != 0:
        return None
    first = strip_ansi(result.stdout).strip().splitlines()
    if not first:
        return None
    return first[0].split()[0] if first[0] else None


def get_recent_dolt_log(dolt_db_dir: Path, n: int = 5) -> list[str]:
    if not _have_dolt():
        return []
    result = run(["dolt", "log", "--oneline", "-n", str(n)], cwd=dolt_db_dir)
    if result.returncode != 0:
        return []
    return [strip_ansi(line) for line in result.stdout.splitlines() if line.strip()]


@functools.cache
def _have_dolt() -> bool:
    return shutil.which("dolt") is not None


def main() -> int:
    parser = argparse.ArgumentParser(
        description=__doc__,
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=(
            "Examples:\n"
            "  dolt-remote-check          Check the current directory\n"
            "  dolt-remote-check <path>   Check a specific beads repo\n"
        ),
    )
    parser.add_argument(
        "project_path", nargs="?", default=".",
        help="Path to the beads project (default: current directory)",
    )
    args = parser.parse_args()

    project_path = resolve_project_path(args.project_path)
    beads_dir = project_path / ".beads"

    db_name, dolt_mode = read_metadata(beads_dir)
    remote_url = get_remote_url(project_path)

    print(f"Repository:  {project_path}")
    print(f"Remote:      {remote_url}")
    print(f"Dolt DB:     {db_name} (mode: {dolt_mode})")
    print()

    remote_ref = get_remote_dolt_ref(project_path)
    if remote_ref is None:
        print("Remote:  refs/dolt/data NOT FOUND")
        print()
        print("Dolt data has never been pushed, or the remote has no dolt ref.")
        print("Run 'bd dolt push' to push.")
        return 1

    print(f"Remote:  refs/dolt/data = {remote_ref[:12]}...")

    last_push, last_commit = read_push_state(beads_dir)
    if last_push is not None:
        print(f"Pushed:  {last_push}")
        print(f"Commit:  {last_commit}")
    else:
        print("Pushed:  (no push-state.json found)")

    dolt_db_dir = locate_dolt_db(beads_dir, db_name)
    if dolt_db_dir is not None:
        remotes = read_dolt_remotes(dolt_db_dir)
        if remotes:
            print()
            print("Dolt remotes configured:")
            for name, url in remotes.items():
                print(f"  {name}: {url}")
        recent = get_recent_dolt_log(dolt_db_dir, n=5)
        if recent:
            print()
            print("Recent Dolt commits (local):")
            for line in recent:
                print(f"  {line}")
    else:
        print()
        print("Warning: Dolt database directory not found")
        print(f"  Checked: {beads_dir / 'embeddeddolt' / db_name}")
        print(f"           {beads_dir / 'dolt' / db_name}")

    print()
    if last_commit is None:
        print("Status:  remote ref exists (no local push state to compare)")
        return 0

    if dolt_db_dir is None or not _have_dolt():
        print("Status:  remote ref exists (install dolt CLI for full sync check)")
        return 0

    local_head = get_local_dolt_head(dolt_db_dir)
    if local_head == last_commit:
        print("Status:  IN SYNC (local HEAD matches last push)")
        return 0

    print("Status:  OUT OF SYNC")
    print(f"  Local HEAD:  {local_head}")
    print(f"  Last pushed: {last_commit}")
    print()
    print("Run 'bd dolt push' to sync.")
    return 1


if __name__ == "__main__":
    sys.exit(main())
