#!/usr/bin/env python3
"""Show recently closed beads in a git-log-style view."""
from __future__ import annotations

import argparse
import json
import subprocess
import sys
from datetime import datetime
from pathlib import Path

from bdutils import error, resolve_project_path


def run_bd_list(project_path: Path, limit: int, since: str | None) -> str:
    cmd = [
        "bd", "list",
        "--status=closed",
        "--sort=closed",
        "--limit", str(limit),
        "--json",
    ]
    if since:
        cmd.append(f"--closed-after={since}")
    try:
        result = subprocess.run(
            cmd, cwd=project_path, capture_output=True, text=True, check=True,
        )
    except FileNotFoundError:
        error("'bd' not found on PATH")
    except subprocess.CalledProcessError as exc:
        if exc.stderr:
            sys.stderr.write(exc.stderr)
        error(f"bd list failed (exit {exc.returncode})")
    return result.stdout


def format_ts(iso: str) -> str:
    if not iso:
        return "?"
    try:
        dt = datetime.fromisoformat(iso.replace("Z", "+00:00"))
    except ValueError:
        return iso
    return dt.astimezone().strftime("%Y-%m-%d %H:%M")


def format_priority(p) -> str:
    if p is None or p == "":
        return "P?"
    try:
        return f"P{int(p)}"
    except (TypeError, ValueError):
        return str(p)


def collapse(s: str) -> str:
    return " ".join(s.split())


def render(issue: dict) -> list[str]:
    ts = format_ts(issue.get("closed_at", ""))
    iid = issue.get("id", "?")
    prio = format_priority(issue.get("priority"))
    itype = issue.get("issue_type", "") or ""
    actor = issue.get("assignee") or issue.get("owner") or ""
    title = collapse(issue.get("title") or "(no title)")
    reason = collapse(issue.get("close_reason") or "")

    head_bits = [f"✓ {ts}", iid, f"{prio} {itype}".strip()]
    if actor:
        head_bits.append(actor)
    lines = ["  ".join(head_bits), f"  {title}"]
    if reason:
        lines.append(f"  {reason}")
    return lines


def main() -> int:
    parser = argparse.ArgumentParser(
        description="Show recently closed beads in a git-log-style view.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=(
            "Examples:\n"
            "  bd-log                         Last 10 closed issues in cwd\n"
            "  bd-log -n 25                   Last 25 closed\n"
            "  bd-log --since 2026-04-01      Closures on/after date\n"
            "  bd-log /path/to/project        Check a different project\n"
        ),
    )
    parser.add_argument(
        "project_path", nargs="?", default=".",
        help="Path to the beads project (default: current directory)",
    )
    parser.add_argument(
        "-n", "--limit", type=int, default=10,
        help="Maximum entries to show (default: 10)",
    )
    parser.add_argument(
        "--since", default=None, metavar="DATE",
        help="Show only closures on/after DATE (YYYY-MM-DD or RFC3339); "
             "passed through to 'bd list --closed-after'.",
    )
    args = parser.parse_args()

    if args.limit <= 0:
        error("--limit must be a positive integer")

    project_path = resolve_project_path(args.project_path)

    raw = run_bd_list(project_path, args.limit, args.since)
    try:
        issues = json.loads(raw) if raw.strip() else []
    except json.JSONDecodeError as exc:
        error(f"could not parse bd list JSON output: {exc}")

    if not issues:
        print("no recently closed issues")
        return 0

    blocks = [render(issue) for issue in issues]
    for i, block in enumerate(blocks):
        if i:
            print()
        for line in block:
            print(line)

    return 0


if __name__ == "__main__":
    sys.exit(main())
